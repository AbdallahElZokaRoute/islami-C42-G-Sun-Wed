<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <ImageView
        android:id="@+id/tasbeeh_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/tasbeeh_bg"
        android:scaleType="fitXY"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <ImageView
        android:id="@+id/islami_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:src="@drawable/islami_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginVertical="20dp"
        />
    <ImageView
        android:id="@+id/sebha_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/sebha_img"
        android:scaleType="centerInside"
        android:layout_gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/islami_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <TextView
        android:id="@+id/sebha_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="سبحان الله"
        android:textSize="35sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="@id/sebha_image"
        app:layout_constraintTop_toTopOf="@id/sebha_image"
        app:layout_constraintStart_toStartOf="@id/sebha_image"
        app:layout_constraintEnd_toEndOf="@id/sebha_image"
        app:layout_constraintVertical_bias="0.55"
       />

    <TextView
        android:id="@+id/counter_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="30"
        android:textSize="35sp"
        android:textColor="@color/white"
        android:layout_marginVertical="20dp"
        app:layout_constraintStart_toStartOf="@id/sebha_image"
        app:layout_constraintEnd_toEndOf="@id/sebha_image"
        app:layout_constraintTop_toBottomOf="@id/sebha_text_view"
        />
</androidx.constraintlayout.widget.ConstraintLayout>