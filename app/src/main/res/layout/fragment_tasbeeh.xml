<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/tasbeeh_fragment_bg">

    <ImageView
        android:id="@+id/quran_image"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:adjustViewBounds="true"
        android:src="@drawable/islami_quran_image"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.15"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/sebha_head"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:adjustViewBounds="true"
        android:src="@drawable/sebha_head"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/sebha_body"
        app:layout_constraintHeight_percent="0.1"
        app:layout_constraintHorizontal_bias="0.6"
        app:layout_constraintStart_toStartOf="@+id/sebha_body"
        app:layout_constraintTop_toBottomOf="@+id/quran_image"
        app:layout_constraintVertical_bias="0.22"
        app:layout_constraintVertical_chainStyle="packed" />

    <ImageView
        android:id="@+id/sebha_body"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:adjustViewBounds="true"
        android:src="@drawable/sebha_body"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent=".5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/quran_image"
        app:layout_constraintVertical_bias="0.7" />

    <TextView
        android:id="@+id/adhkar_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/sebha_body"
        app:layout_constraintEnd_toEndOf="@+id/sebha_body"
        app:layout_constraintStart_toStartOf="@+id/sebha_body"
        app:layout_constraintTop_toTopOf="@+id/sebha_body"
        tools:text="سبحان الله" />

    <TextView
        android:id="@+id/adhkar_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@+id/adhkar_text"
        app:layout_constraintStart_toStartOf="@+id/adhkar_text"
        app:layout_constraintTop_toBottomOf="@+id/adhkar_text"
        tools:text="33" />

</androidx.constraintlayout.widget.ConstraintLayout>
